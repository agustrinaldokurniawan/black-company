# Copy to `.env` in the repo root. Loaded automatically when you run
# `black-company-telegram` with `pip install -e ".[telegram]"` (python-dotenv).
# Never commit real keys.
#
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
#
# Growth memory (milestones SQLite). Default: ./data under current working directory.
# BLACK_COMPANY_DATA_DIR=D:\path\to\data
#
# User ship stub: `ok` (default) or `concerns` — latter records a growth lesson and
# routes PM back to building/pair. Real user agent should call record_lesson on concerns.
# BLACK_COMPANY_USER_SHIP_STUB=concerns
#
# Telegram (pip install -e ".[telegram]")
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
